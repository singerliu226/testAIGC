DASHSCOPE_API_KEY=
# Beijing (mainland China): https://dashscope.aliyuncs.com/compatible-mode/v1
# Singapore (intl): https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Virginia (us): https://dashscope-us.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus-latest
#
# 单次 LLM 请求超时（毫秒）。超时会让该段落记为失败并继续，避免任务“卡死”。
LLM_TIMEOUT_MS=60000

PORT=8787
MAX_UPLOAD_MB=20

# Admin secret for admin panel (billing management)
ADMIN_SECRET=

# ── 营收配置 ──
# 新用户自动赠送的免费积分（用于体验改写功能）
# 建议默认关闭：只提供免费检测即可，避免被薅羊毛
DEFAULT_FREE_POINTS=0

# 计费模式：
# - tokens：按模型返回的 tokens 结算（更贴近真实成本）
# - chars：按字数估算结算（更稳定但与成本偏离）
BILLING_MODE=tokens

# tokens 计费模式下：每 1000 tokens 对应的积分数（可调价）
POINTS_PER_1K_TOKENS=1

# 单次调用最小扣费积分（防止低成本被滥用）
MIN_POINTS_PER_CALL=1

# tokens 计费模式下的预扣倍率：先预扣，模型返回后再补扣/退款
PRECHARGE_MULTIPLIER=1.4

# 管理员微信号（显示在定价弹窗中供用户联系购买）
CONTACT_WECHAT=

# ── 安全配置 ──
# 管理员面板路径混淡：设置后 /admin.html 返回 404，
# 管理面板仅在 /admin-<此值>.html 路径下可访问
# 建议使用随机字符串，如: openssl rand -hex 8
ADMIN_PATH_TOKEN=
