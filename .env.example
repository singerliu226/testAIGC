DASHSCOPE_API_KEY=
# Beijing (mainland China): https://dashscope.aliyuncs.com/compatible-mode/v1
# Singapore (intl): https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Virginia (us): https://dashscope-us.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus-latest

PORT=8787
MAX_UPLOAD_MB=20

# Admin secret for admin panel (billing management)
ADMIN_SECRET=

# ── 营收配置 ──
# 新用户注册自动赠送的免费积分（用于首次体验改写功能）
# 50积分 ≈ 可改写约1万字，够学生体验一个章节
DEFAULT_FREE_POINTS=50

# 管理员微信号（显示在定价弹窗中供用户联系购买）
CONTACT_WECHAT=
